<script is:inline>
  // Navbar logo fade baseado na posição do logo do hero
  (function() {
    var heroLogo = document.querySelector('.hero-logo-svg');
    var navLogo  = document.querySelector('.navbar-logo');
    var navbar   = document.querySelector('.navbar');
    if (!heroLogo || !navLogo || !navbar) return;
    function syncLogoOpacity() {
      var rect      = heroLogo.getBoundingClientRect();
      var navH      = navbar.offsetHeight;
      var fadeStart = rect.height * 1.2 + navH;
      var fadeEnd   = navH;
      var t = (rect.bottom - fadeEnd) / (fadeStart - fadeEnd);
      navLogo.style.opacity = 1 - Math.max(0, Math.min(1, t));
    }
    syncLogoOpacity();
    window.addEventListener('scroll', syncLogoOpacity, { passive: true });
  })();

  // Navbar: highlight active section
  (function() {
    var sections = document.querySelectorAll('section[id]');
    var navLinks = document.querySelectorAll('.navbar-nav a[href^="#"], .navbar-nav a[href^="/#"]');
    window.addEventListener('scroll', function() {
      var current = '';
      sections.forEach(function(s) {
        if (window.scrollY >= s.offsetTop - 100) current = s.getAttribute('id');
      });
      navLinks.forEach(function(link) {
        link.classList.remove('active');
        var href = link.getAttribute('href').replace('/#', '#').replace('/', '');
        if (href === '#' + current) link.classList.add('active');
      });
    });
  })();

  // Quem Somos: chevron de fundo
  (function() {
    var sec = document.getElementById('quem-somos');
    var bg  = sec && sec.querySelector('.qs-chevron-bg');
    if (!bg) return;
    function update() {
      var rect = sec.getBoundingClientRect(), vh = window.innerHeight;
      var mid  = rect.top + rect.height / 2;
      var t    = Math.max(0, 1 - Math.abs(mid - vh / 2) / (vh * 0.65));
      bg.style.opacity = (t * t * 0.14).toString();
    }
    update(); window.addEventListener('scroll', update, { passive: true });
  })();

  // Publicações: dots bg
  (function() {
    var sec = document.getElementById('publicacoes');
    var bg  = sec && sec.querySelector('.publicacoes-dots-bg');
    if (!bg) return;
    function update() {
      var rect = sec.getBoundingClientRect(), vh = window.innerHeight;
      var t;
      if (window.innerWidth <= 768) {
        t = Math.min(Math.max(0, Math.min(1, (vh - rect.top) / (vh * 0.7))), Math.max(0, Math.min(1, rect.bottom / (vh * 0.6))));
      } else {
        t = Math.max(0, 1 - Math.abs(rect.top + rect.height / 2 - vh / 2) / (vh * 1.10));
      }
      bg.style.opacity = (t * t * 0.10).toString();
    }
    update(); window.addEventListener('scroll', update, { passive: true });
  })();

  // Fundos: lines bg
  (function() {
    var sec = document.getElementById('fundos');
    var bg  = sec && sec.querySelector('.fundos-lines-bg');
    if (!bg) return;
    function update() {
      var rect = sec.getBoundingClientRect(), vh = window.innerHeight;
      var t;
      if (window.innerWidth <= 768) {
        t = Math.min(Math.max(0, Math.min(1, (vh - rect.top) / (vh * 0.7))), Math.max(0, Math.min(1, rect.bottom / (vh * 0.6))));
      } else {
        t = Math.max(0, 1 - Math.abs(rect.top + rect.height / 2 - vh / 2) / (vh * 1.10));
      }
      bg.style.opacity = (t * t * 0.045).toString();
    }
    update(); window.addEventListener('scroll', update, { passive: true });
  })();

  // Diferenciais: dots bg
  (function() {
    var sec = document.getElementById('diferenciais');
    var bg  = sec && sec.querySelector('.diferenciais-dots-bg');
    if (!bg) return;
    function update() {
      var rect = sec.getBoundingClientRect(), vh = window.innerHeight;
      var t;
      if (window.innerWidth <= 768) {
        t = Math.min(Math.max(0, Math.min(1, (vh - rect.top) / (vh * 0.7))), Math.max(0, Math.min(1, rect.bottom / (vh * 0.6))));
      } else {
        t = Math.max(0, 1 - Math.abs(rect.top + rect.height / 2 - vh / 2) / (vh * 1.10));
      }
      bg.style.opacity = (t * t * 0.084).toString();
    }
    update(); window.addEventListener('scroll', update, { passive: true });
  })();

  // Serviços: 360 bg
  (function() {
    var sec = document.getElementById('servicos');
    var bg  = sec && sec.querySelector('.servicos-360-bg');
    if (!bg) return;
    function update() {
      var rect = sec.getBoundingClientRect(), vh = window.innerHeight;
      var t;
      if (window.innerWidth <= 768) {
        t = Math.min(Math.max(0, Math.min(1, (vh - rect.top) / (vh * 0.7))), Math.max(0, Math.min(1, rect.bottom / (vh * 0.6))));
        bg.style.opacity = (t * t * 0.048).toString();
      } else {
        t = Math.max(0, 1 - Math.abs(rect.top + rect.height / 2 - vh / 2) / (vh * 1.10));
        bg.style.opacity   = (t * t * 0.048).toString();
        bg.style.transform = 'translateY(-50%)';
      }
    }
    update(); window.addEventListener('scroll', update, { passive: true });
  })();

  // Serviços: toggle cards + painel desktop
  (function() {
    var cards   = document.querySelectorAll('.servico-card');
    var panel   = document.getElementById('servicosDetailPanel');
    var section = document.getElementById('servicos');
    var conts   = panel ? panel.querySelectorAll('.svc-detail-content') : [];
    var closeTimer = null, expandedH = 0;

    function setH() { if (expandedH > 0) section.style.minHeight = expandedH + 'px'; }
    function clearH() { section.style.minHeight = ''; }

    function closePanel() {
      if (!panel) return;
      panel.classList.remove('is-open');
      clearTimeout(closeTimer);
      closeTimer = setTimeout(function() { conts.forEach(function(c) { c.classList.remove('is-active'); }); clearH(); }, 460);
    }

    function openPanel(id) {
      if (!panel) return false;
      var cont = panel.querySelector('[data-svc="' + id + '"]');
      if (!cont) return false;
      clearTimeout(closeTimer);
      conts.forEach(function(c) { c.classList.remove('is-active'); });
      cont.classList.add('is-active');
      setH();
      panel.classList.add('is-open');
      return true;
    }

    cards.forEach(function(card) {
      card.addEventListener('click', function(e) {
        if (e.target.closest && e.target.closest('.servico-inline-detail')) return;
        var id = card.dataset.svc, isMobile = window.innerWidth <= 768, wasOpen = card.classList.contains('is-open');
        cards.forEach(function(c) { c.classList.remove('is-open'); });
        if (wasOpen) {
          if (!isMobile) closePanel();
        } else {
          card.classList.add('is-open');
          if (!isMobile) openPanel(id);
        }
        cards.forEach(function(c) {
          var t = c.querySelector('.servico-toggle');
          if (t) t.setAttribute('aria-expanded', c.classList.contains('is-open').toString());
        });
      });
    });

    window.addEventListener('load', function() {
      if (window.innerWidth <= 768 || !section || !panel) return;
      var naturalH = section.offsetHeight, panelW = panel.offsetWidth || section.offsetWidth;
      var probe = document.createElement('div');
      probe.style.cssText = 'position:fixed;visibility:hidden;top:0;left:0;width:' + panelW + 'px;pointer-events:none;z-index:-1;';
      document.body.appendChild(probe);
      var maxH = 0;
      Array.from(conts).forEach(function(cont) {
        var clone = cont.cloneNode(true);
        clone.style.cssText = 'display:flex;padding:40px 48px;gap:56px;align-items:flex-start;';
        probe.appendChild(clone);
        void clone.offsetHeight;
        if (clone.offsetHeight > maxH) maxH = clone.offsetHeight;
        probe.removeChild(clone);
      });
      document.body.removeChild(probe);
      if (maxH > 0) expandedH = naturalH + maxH + 12;
    });
  })();

  // Quem Somos: expand
  (function() {
    var trigger  = document.getElementById('qsExpandTrigger');
    var collapse = document.getElementById('qsCollapseTrigger');
    var exp      = document.getElementById('qsExpandable');
    var label    = trigger && trigger.querySelector('.qs-expand-label');
    if (!trigger || !exp) return;
    function toggle(scrollNext) {
      var isOpen = exp.classList.toggle('open');
      trigger.classList.toggle('open', isOpen);
      trigger.setAttribute('aria-expanded', isOpen);
      if (label) label.textContent = isOpen ? 'Ver menos' : 'Saiba mais';
      if (!isOpen && scrollNext) {
        setTimeout(function() { document.getElementById('servicos').scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 780);
      }
    }
    trigger.addEventListener('click', function() { toggle(false); });
    if (collapse) collapse.addEventListener('click', function() { toggle(true); });
  })();

  // Fundos: expand análise
  (function() {
    var trigger = document.getElementById('fundosExpandTrigger');
    var exp     = document.getElementById('fundosExpandable');
    var label   = trigger && trigger.querySelector('.fundos-expand-label');
    if (!trigger || !exp) return;
    trigger.addEventListener('click', function() {
      var isOpen = exp.classList.toggle('open');
      trigger.classList.toggle('open', isOpen);
      trigger.setAttribute('aria-expanded', isOpen);
      if (label) label.textContent = isOpen ? 'Ver menos' : 'Análise';
    });
  })();

  // Diferenciais: expand
  (function() {
    var trigger = document.getElementById('diferenciaisExpandTrigger');
    var exp     = document.getElementById('diferenciaisExpandable');
    var label   = trigger && trigger.querySelector('.fundos-expand-label');
    if (!trigger || !exp) return;
    trigger.addEventListener('click', function() {
      var isOpen = exp.classList.toggle('open');
      trigger.classList.toggle('open', isOpen);
      trigger.setAttribute('aria-expanded', isOpen);
      if (label) label.textContent = isOpen ? 'Ver menos' : 'Saiba mais';
    });
  })();

  // Quem Somos: carrossel
  (function() {
    var track  = document.getElementById('qsCarouselTrack');
    var dots   = document.querySelectorAll('#qsCarouselDots .qs-carousel-dot');
    var slides = document.querySelectorAll('#qsCarousel .qs-carousel-slide');
    if (!track || !slides.length) return;
    var current = 0;
    function goTo(idx) {
      current = (idx + slides.length) % slides.length;
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
      dots.forEach(function(d, i) { d.classList.toggle('active', i === current); });
    }
    document.getElementById('qsCarouselPrev').addEventListener('click', function() { goTo(current - 1); });
    document.getElementById('qsCarouselNext').addEventListener('click', function() { goTo(current + 1); });
    dots.forEach(function(d) { d.addEventListener('click', function() { goTo(+d.dataset.idx); }); });
    var startX = 0;
    track.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', function(e) {
      var diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(current + (diff > 0 ? 1 : -1));
    });
    setInterval(function() {
      if (document.getElementById('qsExpandable').classList.contains('open')) goTo(current + 1);
    }, 5000);
    goTo(0);
  })();

  // Copiar e-mail
  (function() {
    var btn     = document.getElementById('copyEmailBtn');
    var tooltip = document.getElementById('copyTooltip');
    if (!btn) return;
    btn.addEventListener('click', function() {
      navigator.clipboard.writeText('contato@mzrfo.com.br').then(function() {
        tooltip.classList.add('show');
        setTimeout(function() { tooltip.classList.remove('show'); }, 1800);
      });
    });
  })();

  // Endereço: Google Maps (desktop) ou picker (mobile)
  function handleAddressClick(e) {
    if (/Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent)) {
      e.stopPropagation();
      document.getElementById('mapPicker').classList.toggle('open');
    } else {
      window.open('https://maps.google.com/?q=Rua+Joaquim+Floriano,+820,+São+Paulo,+SP', '_blank', 'noopener');
