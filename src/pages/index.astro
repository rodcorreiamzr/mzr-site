    if (picker && !picker.contains(e.target) && !e.target.closest('.contato-address-btn')) {
      picker.classList.remove('open');
    }
  });

  // Diferenciais: auto-ciclo
  (function() {
    var items = Array.from(document.querySelectorAll('.diferencial-item'));
    if (!items.length) return;
    var idx = 0, FADE = 1200, HOLD = 2400, started = false;
    function applyTransition(item) {
      item.style.transition = 'opacity ' + (FADE/1000) + 's ease-in-out, background ' + (FADE/1000) + 's ease-in-out, border-color ' + (FADE/1000) + 's ease-in-out';
    }
    function startCycle() {
      if (started) return;
      started = true;
      setTimeout(function() {
        items.forEach(function(item, i) {
          applyTransition(item);
          item.style.opacity = i === 0 ? '1' : '0.32';
          if (i === 0) item.classList.add('active');
        });
        setInterval(function() {
          items[idx].style.opacity = '0.32';
          items[idx].classList.remove('active');
          idx = (idx + 1) % items.length;
          items[idx].style.opacity = '1';
          items[idx].classList.add('active');
        }, HOLD + FADE);
      }, 900);
    }
    var section = document.getElementById('diferenciais');
    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting) { startCycle(); obs.disconnect(); }
      }, { threshold: 0.25 });
      obs.observe(section);
    } else { startCycle(); }
  })();

  // Fundo Modal
  var fundoData = {
