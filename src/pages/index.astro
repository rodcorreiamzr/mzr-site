---
import Base from '../layouts/Base.astro';
import { getUltimasPublicacoes, getFundoDocumentos, getPrestacaoContas } from '../lib/sanity';
const publicacoes = await getUltimasPublicacoes(6);
const fundoDocs = await getFundoDocumentos();
const prestacao = await getPrestacaoContas();
const prestacaoUrl = prestacao ? '/prestacao-de-contas' : null;

function formatDate(dateStr: string) {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' });
}
---

<Base
  title="MZR Family Office — Multi-Family Office Completo e Independente"
  description="Gestão do patrimônio global de famílias, no Brasil e no exterior."
  ogImage={new URL('/og-home.jpg', Astro.site).href}
>

<style is:global>

  /* ── Navbar logo: invisível no hero, aparece ao rolar ── */
  .navbar-logo { opacity: 0; }

  /* ── Botões ── */
  .btn-primary {
    background: var(--gold-400);
    color: var(--navy-800);
    font-family: 'Work Sans', sans-serif;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.01em;
    padding: 14px 32px;
    border-radius: 8px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover { background: var(--gold-500); transform: translateY(-1px); }
  .btn-primary svg { transition: transform 0.2s ease; }
  .btn-primary:hover svg { transform: translateX(4px); }
  .btn-text-gold {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Work Sans', sans-serif;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold-400);
    text-decoration: none;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.2s;
  }
  .btn-text-gold:hover { opacity: 0.75; }
  .btn-text-gold svg { transition: transform 0.2s ease; }
  .btn-text-gold:hover svg { transform: translateX(4px); }
  .btn-secondary {
    background: transparent;
    color: rgba(255,255,255,0.85);
    font-family: 'Work Sans', sans-serif;
    font-weight: 500;
    font-size: 14px;
    padding: 14px 32px;
    border-radius: 8px;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.25);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-secondary:hover { border-color: rgba(255,255,255,0.5); color: #fff; }

  /* ── Divider ── */
  .divider { height: 1px; background: var(--neutral-200); margin: 0 48px; }
  @media (max-width: 768px) { .divider { margin: 0 24px; } }

  /* ── Keyframes exclusivos da home ── */
  @keyframes letterIn {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes revealLTR {
    from { clip-path: inset(0 100% 0 0); }
    to   { clip-path: inset(0 0% 0 0); }
  }
  @keyframes scrollDrop {
    0%   { top: -100%; }
    50%  { top: 100%; }
    100% { top: 100%; }
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--navy-700);
  }
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0.35;
    z-index: 0;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(29,53,87,0.10) 0%, rgba(29,53,87,0.05) 40%, rgba(29,53,87,0.14) 100%);
    z-index: 1;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    width: 100%;
    max-width: 1200px;
    padding: 0 48px;
    margin: 0 auto;
  }
  .hero-logo-svg {
    width: clamp(110px, 14vw, 190px);
    height: auto;
    display: block;
    transform: translateX(-13.97%);
  }
  .logo-g-M { opacity: 0; animation: fadeIn 0.43s ease 0.26s forwards; }
  .logo-g-Z { opacity: 0; animation: fadeIn 0.43s ease 0.60s forwards; }
  .logo-g-R { opacity: 0; animation: fadeIn 0.43s ease 0.94s forwards; }
  .logo-g-chevron { opacity: 0; animation: fadeIn 0.43s ease 1.28s forwards; }
  .logo-g-line   { animation: revealLTR 0.38s ease-out 1.62s both; }
  .logo-g-family { animation: revealLTR 0.60s ease-out 1.83s both; }
  .logo-g-office { animation: revealLTR 0.60s ease-out 2.04s both; }
  .hero-tagline h1 { opacity: 0; animation: fadeIn 1.8s ease 2.3s forwards; max-width: 640px; }
  .hero-tagline p {
    white-space: nowrap;
    font-size: clamp(13px, 1.8vw, 18px);
    font-weight: 400;
    color: rgba(255,255,255,0.65);
    line-height: 1.65;
    letter-spacing: -0.005em;
    opacity: 0;
    animation: fadeIn 1.6s ease 3.3s forwards;
  }
  @media (max-width: 640px) {
    .hero-tagline p { white-space: normal; }
  }
  .hero-scroll {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    opacity: 0;
    animation: fadeIn 0.5s ease 3s forwards;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .hero-scroll span {
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    font-weight: 600;
    transition: color 0.25s ease;
  }
  .hero-scroll:hover span { color: var(--gold-400); }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,0.20);
    position: relative;
    overflow: hidden;
    transition: background 0.25s ease;
  }
  .hero-scroll:hover .scroll-line { background: rgba(201,167,124,0.30); }
  .scroll-line::after {
    content: '';
    position: absolute;
    top: -100%; left: 0;
    width: 100%; height: 100%;
    background: var(--gold-400);
    animation: scrollDrop 1.8s ease-in-out 3.2s infinite;
  }

  /* ── Strip Instituições ── */
  .strip-institucoes {
    background: var(--navy-800);
    padding: 36px 0;
    overflow: hidden;
  }
  .strip-institucoes-label {
    text-align: center;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.28);
    margin-bottom: 24px;
  }
  .strip-track-outer {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 10%, #000 90%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, #000 10%, #000 90%, transparent 100%);
  }
  .strip-track {
    display: flex;
    width: max-content;
    animation: marquee 36s linear infinite;
  }
  .strip-track:hover { animation-play-state: paused; }
  .strip-logos { display: flex; align-items: center; gap: 0; }
  .inst-logo {
    font-family: 'Work Sans', sans-serif;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.32);
    white-space: nowrap;
    user-select: none;
    padding: 0 40px;
    position: relative;
  }
  .inst-logo::after {
    content: '';
    position: absolute;
    right: 0; top: 50%;
    transform: translateY(-50%);
    width: 3px; height: 3px;
    border-radius: 50%;
    background: rgba(201,167,124,0.30);
  }

  /* ── Quem Somos ── */
  #quem-somos { background: var(--neutral-100); padding: 72px 0 48px; position: relative; overflow: hidden; }
  #quem-somos .section-inner { position: relative; z-index: 1; }
  .qs-chevron-bg {
    position: absolute;
    right: -3%; top: 50%;
    transform: translateY(-50%);
    width: 44%; height: auto;
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }
  .quem-somos-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    margin-top: 40px;
  }
  .quem-somos-text p { font-size: 16px; line-height: 1.80; color: var(--neutral-700); max-width: 520px; }
  .quem-somos-text p + p { margin-top: 20px; }
  .quem-somos-stats { display: grid; grid-template-columns: max-content; gap: 24px; }
  .stat-card { background: var(--white); border: 1px solid var(--neutral-200); border-radius: 12px; padding: 28px; }
  .stat-value { font-size: 40px; font-weight: 700; color: var(--navy-700); line-height: 1; font-variant-numeric: tabular-nums; letter-spacing: -0.02em; margin-bottom: 6px; }
  .stat-value span { font-size: 22px; font-weight: 600; color: var(--gold-600); }
  .stat-label { font-size: 13px; color: var(--neutral-400); line-height: 1.4; }
  .qs-expand-trigger {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 36px 0 0;
    cursor: pointer;
    background: none;
    border: none;
    width: 100%;
    font-family: 'Work Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--navy-700);
    opacity: 0.5;
    transition: opacity 0.2s;
    position: relative;
    z-index: 2;
  }
  .qs-expand-trigger:hover { opacity: 0.9; }
  .qs-expand-arrow { transition: transform 0.45s ease; }
  .qs-expand-trigger.open .qs-expand-arrow { transform: rotate(180deg); }
  .qs-expand-trigger.dark { color: rgba(255,255,255,0.55); }
  .qs-expandable { max-height: 0; overflow: hidden; transition: max-height 0.75s ease; background: var(--neutral-100); }
  .qs-expandable.open { max-height: 1100px; }
  .qs-expand-content { padding-top: 24px; padding-bottom: 72px; }
  .qs-expand-content p { font-size: clamp(15px, 1.3vw, 17px); color: var(--navy-700); line-height: 1.80; max-width: 780px; opacity: 0.85; }
  .qs-expand-subtitle { font-family: 'Spectral', serif; font-weight: 400; font-size: clamp(20px, 2vw, 28px); color: var(--navy-800); margin-top: 52px; margin-bottom: 28px; }
  .qs-carousel { position: relative; overflow: hidden; border-radius: 12px; max-width: 860px; }
  .qs-carousel-track { display: flex; transition: transform 0.5s ease; }
  .qs-carousel-slide { flex: 0 0 100%; }
  .qs-carousel-slide img { width: 100%; height: 460px; object-fit: cover; display: block; }
  .qs-carousel-btn {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,0.82); border: none; border-radius: 50%;
    width: 42px; height: 42px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s; color: var(--navy-800);
  }
  .qs-carousel-btn:hover { background: #fff; }
  .qs-carousel-prev { left: 14px; }
  .qs-carousel-next { right: 14px; }
  .qs-carousel-dots { display: flex; justify-content: center; gap: 8px; margin-top: 14px; max-width: 860px; }
  .qs-carousel-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--navy-700); opacity: 0.2;
    cursor: pointer; border: none; padding: 0; transition: opacity 0.25s;
  }
  .qs-carousel-dot.active { opacity: 0.65; }
  @media (max-width: 768px) { .qs-carousel-slide img { height: 240px; } }

  /* ── Serviços ── */
  #servicos { background: var(--white); position: relative; overflow: hidden; }
  #servicos .section-inner { position: relative; z-index: 1; }
  .servicos-360-bg { position: absolute; right: -6%; top: 50%; transform: translateY(-50%); width: 62%; height: auto; opacity: 0; pointer-events: none; z-index: 0; will-change: opacity; }
  .servicos-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-top: 56px; }
  .servico-card { background: var(--neutral-50); border: 1px solid var(--neutral-200); border-radius: 12px; padding: 28px 28px 58px; position: relative; cursor: pointer; transition: border-color 0.2s, box-shadow 0.2s, background 0.2s; }
  .servico-card:hover { border-color: var(--navy-300); box-shadow: 0 4px 24px rgba(29,53,87,0.08); }
  .servico-card.is-open { background: var(--navy-800); border-color: var(--navy-800); }
  .servico-card-top { display: flex; align-items: center; gap: 14px; }
  .servico-icon { width: 44px; height: 44px; border-radius: 10px; background: var(--navy-50); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background 0.2s; }
  .servico-icon svg { stroke: var(--navy-700); transition: stroke 0.2s; }
  .servico-card.is-open .servico-icon { background: rgba(255,255,255,0.12); }
  .servico-card.is-open .servico-icon svg { stroke: rgba(255,255,255,0.85); }
  .servico-card h3 { font-family: 'Work Sans', sans-serif; font-weight: 600; font-size: 15px; color: var(--navy-800); line-height: 1.3; letter-spacing: -0.01em; transition: color 0.2s; }
  .servico-card.is-open h3 { color: #fff; }
  .servico-toggle { position: absolute; bottom: 18px; right: 18px; width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid var(--neutral-400); background: transparent; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s, border-color 0.2s, color 0.2s; color: var(--neutral-500); padding: 0; }
  .servico-card:hover .servico-toggle { border-color: var(--navy-400); color: var(--navy-500); }
  .servico-card.is-open .servico-toggle { background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.35); color: #fff; }
  .servico-toggle-icon { display: flex; align-items: center; justify-content: center; transition: transform 0.3s cubic-bezier(0.4,0,0.2,1); }
  .servico-card.is-open .servico-toggle-icon { transform: rotate(45deg); }
  .servico-inline-detail { display: none; }
  .servicos-detail-panel { display: grid; grid-template-rows: 0fr; background: var(--navy-800); border-radius: 12px; margin-top: 0; transition: grid-template-rows 0.45s cubic-bezier(0.4,0,0.2,1), margin-top 0.3s ease, opacity 0.3s ease; opacity: 0; }
  .servicos-detail-panel.is-open { grid-template-rows: 1fr; margin-top: 12px; opacity: 1; }
  .servicos-detail-inner { overflow: hidden; min-height: 0; }
  .svc-detail-content { display: none; padding: 40px 48px; gap: 56px; }
  .svc-detail-content.is-active { display: flex; align-items: flex-start; }
  .svc-detail-left { flex-shrink: 0; width: 210px; }
  .svc-detail-icon { width: 52px; height: 52px; border-radius: 12px; background: rgba(255,255,255,0.10); display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
  .svc-detail-icon svg { stroke: rgba(255,255,255,0.85); }
  .svc-detail-title { font-family: 'Spectral', serif; font-weight: 400; font-size: 20px; color: #fff; line-height: 1.25; }
  .svc-detail-subtitle { font-size: 11px; font-weight: 500; color: var(--gold-400); letter-spacing: 0.07em; text-transform: uppercase; margin-top: 6px; }
  .servico-inline-subtitle { font-size: 11px; font-weight: 500; color: var(--gold-400); letter-spacing: 0.07em; text-transform: uppercase; margin-bottom: 10px; }
  .svc-detail-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 14px; }
  .svc-detail-list li { display: flex; align-items: flex-start; gap: 12px; color: rgba(255,255,255,0.78); font-size: 14px; line-height: 1.6; }
  .svc-detail-list li::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--gold-400); margin-top: 7px; flex-shrink: 0; }

  /* ── Diferenciais ── */
  #diferenciais { background: var(--navy-700); position: relative; overflow: hidden; isolation: isolate; }
  #diferenciais .section-inner { position: relative; z-index: 1; }
  #diferenciais .overline { color: var(--gold-400); }
  #diferenciais .section-title { color: #fff; }
  #diferenciais .section-lead { color: rgba(255,255,255,0.65); }
  .diferenciais-dots-bg { position: absolute; right: -2%; top: 0; width: 55%; height: auto; opacity: 0; pointer-events: none; z-index: 0; filter: invert(1); mix-blend-mode: screen; will-change: opacity; }
  .diferenciais-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; overflow: hidden; margin-top: 56px; }
  .diferencial-item { background: var(--navy-700); padding: 36px 28px; display: flex; flex-direction: column; gap: 12px; border-left: 2px solid transparent; }
  .diferencial-item.active { background: var(--navy-800); border-left-color: var(--gold-400); }
  .diferencial-num { font-size: 10px; font-weight: 600; letter-spacing: 0.22em; color: var(--gold-400); text-transform: uppercase; }
  .diferencial-title { font-family: 'Spectral', serif; font-weight: 400; font-size: 22px; color: #fff; line-height: 1.25; letter-spacing: -0.01em; }
  .diferenciais-expandable { max-height: 0; overflow: hidden; transition: max-height 0.75s ease; }
  .diferenciais-expandable.open { max-height: 600px; }
  .diferenciais-expand-content { padding-top: 8px; padding-bottom: 28px; }
  .diferenciais-expand-content p { font-size: clamp(15px, 1.3vw, 17px); color: rgba(255,255,255,0.72); line-height: 1.80; max-width: 860px; margin-bottom: 20px; }
  .diferenciais-expand-content ul { padding-left: 0; list-style: none; display: flex; flex-direction: column; gap: 10px; max-width: 860px; }
  .diferenciais-expand-content li { font-size: clamp(15px, 1.3vw, 17px); color: rgba(255,255,255,0.72); line-height: 1.72; padding-left: 18px; position: relative; }
  .diferenciais-expand-content li::before { content: ''; position: absolute; left: 0; top: 11px; width: 5px; height: 5px; border-radius: 50%; background: var(--gold-400); opacity: 0.7; }

  /* ── Fundos ── */
  #fundos { background: var(--neutral-50); position: relative; overflow: hidden; isolation: isolate; }
  #fundos .section-inner { position: relative; z-index: 1; }
  .fundos-lines-bg { position: absolute; left: -15%; top: 50%; transform: translateY(-50%); width: 128%; height: auto; opacity: 0; pointer-events: none; z-index: 0; mix-blend-mode: multiply; will-change: opacity; }
  .fundos-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 40px; }
  .fundos-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .estrategia-card { background: var(--navy-800); border-radius: 12px; padding: 32px 28px; display: flex; flex-direction: column; justify-content: space-between; min-height: 180px; transition: background 0.2s, box-shadow 0.2s; cursor: pointer; }
  .estrategia-card:hover { background: var(--navy-700); box-shadow: 0 8px 32px rgba(10,23,39,0.18); }
  .estrategia-card-tag { font-size: 10px; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold-400); margin-bottom: 16px; }
  .estrategia-card-name { font-family: 'Spectral', serif; font-weight: 400; font-size: clamp(20px, 2vw, 26px); color: #fff; line-height: 1.20; letter-spacing: -0.01em; flex: 1; }
  .estrategia-card-line { width: 28px; height: 2px; background: var(--gold-400); margin-top: 24px; opacity: 0.6; }
  .fundo-disclaimer { font-size: 11px; color: var(--neutral-400); line-height: 1.6; margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--neutral-200); max-width: 720px; }
  .fundos-expandable { max-height: 0; overflow: hidden; transition: max-height 0.75s ease; }
  .fundos-expandable.open { max-height: 1200px; }
  .fundos-expand-content { padding-top: 8px; padding-bottom: 28px; }
  .fundos-expand-title { font-family: 'Spectral', serif; font-weight: 400; font-size: clamp(20px, 2vw, 28px); color: var(--navy-800); margin-bottom: 28px; }
  .fundos-expand-content p { font-size: clamp(15px, 1.3vw, 17px); color: var(--navy-700); line-height: 1.80; max-width: 860px; opacity: 0.85; margin-bottom: 20px; }
  .fundos-expand-content p:last-of-type { margin-bottom: 0; }

  /* ── Fundo Modal ── */
  .fundo-modal-nav { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.13); border-radius: 50%; width: 42px; height: 42px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: rgba(255,255,255,0.50); transition: background 0.2s, color 0.2s; z-index: 10; flex-shrink: 0; }
  .fundo-modal-nav:hover { background: rgba(255,255,255,0.14); color: #fff; }
  .fundo-modal-nav-prev { left: 20px; }
  .fundo-modal-nav-next { right: 20px; }
  @media (max-width: 780px) { .fundo-modal-nav { display: none; } }
  #fundoModal.fundo-modal-backdrop { z-index: 1100; background: rgba(10,23,39,0.72); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); }
  #fundoModal .fundo-modal { padding: 48px 52px; max-width: 680px; transform: translateY(18px); transition: transform 0.28s ease; }
  #fundoModal.fundo-modal-backdrop.open .fundo-modal { transform: translateY(0); }
  .fundo-modal-desc { font-size: 15px; color: rgba(255,255,255,0.72); line-height: 1.75; margin-bottom: 36px; }
  .fundo-modal-docs-label { font-size: 10px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.38); margin-bottom: 16px; }
  .fundo-modal-docs { display: flex; flex-direction: column; gap: 12px; }
