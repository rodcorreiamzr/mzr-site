    pevc: {
      tag: 'Alternativos', title: 'Allocation PE/VC',
      desc: 'Com objetivo de diversificar a alocação de nossos clientes em participações de empresas privadas, o Allocation PE/VC investe em 12 fundos, entre as categorias de Venture Capital, Private Equity e Special Situations, possibilitando a alocação em diversas gestoras, estratégias, setores e companhias com um cheque mínimo reduzido versus a média da indústria. O veículo é um FIP local para investidores profissionais com mecanismo de chamada de capital.',
      docsLabel: 'Documentos',
      docs: [{ label: 'Fatos Relevantes', subContent: { tag: 'Alternativos', title: 'Fatos Relevantes', subtitle: 'Allocation Alternativos PE/VC II Fundo de Investimento em Participações Multiestratégia IE', docsLabel: 'Fatos Relevantes a partir de setembro/2025', links: [{ label: '01 de Setembro de 2025', href: '#' }, { label: '04 de Setembro de 2025', href: '#' }, { label: '26 de Novembro de 2025', href: '#' }, { label: '09 de Março de 2026', href: '#' }] } }],
      gestorasSafras: [
        { label: 'Safra I (2022)', items: ['XP Spec. Opp', 'Vinci', 'Monashees', 'ONEVC', 'Shift Capital', 'Mindset Vent.', 'Cloud 9', 'Kinea', 'Starboard III', 'Strata Capital', 'Norte Ventures', 'BlueOak', 'Riverwood', 'Mission Co', 'Soma Capital'] },
        { label: 'Safra II (2025)', items: ['Starboard', 'Perfin', 'Kanoa Capital', 'Strata', 'General Atlantic', 'Cloud 9', 'Big Bets', 'Hypersphere', 'Warburg Pincus', 'Radix', 'ONEVC Fund III', 'Central', 'Vinci VCP IV'] }
      ]
    }
  };

  // ── Overlay dos documentos vindos do Sanity ──
  // Se houver registro no Sanity para um fundo, ele substitui os placeholders de docs/fatos
  // relevantes (label + href reais). Sem registro, mantém os placeholders acima como fallback.
  (function() {
    var SD = window.__fundoDocs || {};
    function toLinks(arr) {
      return (arr || []).filter(function(x) { return x && x.label; })
        .map(function(x) { return { label: x.label, href: x.url || '#' }; });
    }
    ['multimercado', 'globalequities', 'cicloolimpico'].forEach(function(k) {
      var docs = SD[k] && toLinks(SD[k].documentos);
      if (docs && docs.length) fundoData[k].docs = docs;
    });
    // Ciclo Olímpico: anexa a Prestação de Contas (página dedicada) se houver uma publicada.
    if (window.__prestacaoUrl) {
      fundoData.cicloolimpico.docs = (fundoData.cicloolimpico.docs || []).concat([
        { label: 'Prestação de Contas', href: window.__prestacaoUrl, internal: true }
      ]);
    }
    if (SD.pevc) {
      var fatos = toLinks(SD.pevc.fatosRelevantes);
      if (fatos.length) fundoData.pevc.docs[0].subContent.links = fatos;
      var pevcDocs = toLinks(SD.pevc.documentos);
      if (pevcDocs.length) fundoData.pevc.docs = fundoData.pevc.docs.concat(pevcDocs);
    }
  })();

  var docIcon    = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';
  var navChevron = '<svg class="doc-nav-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>';
  var _fundoSubs = [], _currentFundoId = null;
  var fundoOrder = ['multimercado', 'globalequities', 'cicloolimpico', 'pevc'];

  function setFundoNavVisible(v) {
    var d = v ? '' : 'none';
    document.getElementById('fundoModalPrev').style.display = d;
    document.getElementById('fundoModalNext').style.display = d;
  }

  function openFundoModal(id) {
    var d = fundoData[id]; if (!d) return;
    _currentFundoId = id;
    document.getElementById('fundoModalScreenMain').style.display = '';
    document.getElementById('fundoModalScreenSub').style.display = 'none';
    setFundoNavVisible(true);
    document.getElementById('fundoModalTag').textContent = d.tag;
    document.getElementById('fundoModalTitle').textContent = d.title;
    var descEl = document.getElementById('fundoModalDesc');
    descEl.textContent = d.desc; descEl.style.display = d.desc ? '' : 'none';
    var hasDocs = d.docs && d.docs.length > 0;
    document.getElementById('fundoModalDivider').style.display = hasDocs ? '' : 'none';
    var docsLabelEl = document.getElementById('fundoModalDocsLabel');
    docsLabelEl.style.display = hasDocs ? '' : 'none';
    docsLabelEl.textContent = d.docsLabel || 'Lâminas';
    _fundoSubs = [];
    document.getElementById('fundoModalDocs').innerHTML = hasDocs ? d.docs.map(function(doc, i) {
      if (doc.subContent) { _fundoSubs[i] = doc.subContent; return '<button class="fundo-modal-doc-nav" onclick="navigateToFundoSub(' + i + ')">' + docIcon + doc.label + navChevron + '</button>'; }
      if (doc.internal) { return '<a href="' + doc.href + '" class="fundo-modal-doc-link">' + docIcon + doc.label + navChevron + '</a>'; }
      return '<a href="' + doc.href + '" class="fundo-modal-doc-link" target="_blank" rel="noopener">' + docIcon + doc.label + '</a>';
    }).join('') : '';
    var hasGestoras = d.gestorasSafras && d.gestorasSafras.length > 0;
    var gesWrap = document.getElementById('fundoModalGestorasWrap');
    gesWrap.style.display = hasGestoras ? '' : 'none';
    if (hasGestoras) document.getElementById('fundoModalGestoras').innerHTML = d.gestorasSafras.map(function(safra) {
      return '<div class="fundo-modal-safra-label">' + safra.label + '</div><div class="fundo-modal-gestoras">' +
        safra.items.map(function(g) { return '<div class="fundo-modal-gestora-item">' + g + '</div>'; }).join('') + '</div>';
    }).join('');
    document.getElementById('fundoModal').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function navigateToFundoSub(idx) {
    var sub = _fundoSubs[idx]; if (!sub) return;
    document.getElementById('fundoModalSubTag').textContent = sub.tag || '';
    document.getElementById('fundoModalSubTitle').textContent = sub.title;
    var subtitleEl = document.getElementById('fundoModalSubSubtitle');
    subtitleEl.textContent = sub.subtitle || ''; subtitleEl.style.display = sub.subtitle ? '' : 'none';
    document.getElementById('fundoModalSubDocsLabel').textContent = sub.docsLabel || 'Links';
    document.getElementById('fundoModalSubDocs').innerHTML = sub.links.map(function(l) { return '<a href="' + l.href + '" class="fundo-modal-doc-link" target="_blank" rel="noopener">' + docIcon + l.label + '</a>'; }).join('');
    var main = document.getElementById('fundoModalScreenMain'), sub2 = document.getElementById('fundoModalScreenSub');
    main.style.display = 'none'; sub2.style.opacity = '0'; sub2.style.display = 'block';
    requestAnimationFrame(function() { sub2.style.transition = 'opacity 0.22s ease'; sub2.style.opacity = '1'; });
    setFundoNavVisible(false);
    document.querySelector('#fundoModal .fundo-modal').scrollTop = 0;
  }

  function navigateToFundoMain() {
    document.getElementById('fundoModalScreenSub').style.display = 'none';
    var main = document.getElementById('fundoModalScreenMain');
    main.style.opacity = '0'; main.style.display = '';
    requestAnimationFrame(function() { main.style.transition = 'opacity 0.22s ease'; main.style.opacity = '1'; });
    setFundoNavVisible(true);
    document.querySelector('#fundoModal .fundo-modal').scrollTop = 0;
  }

  function closeFundoModal() {
    document.getElementById('fundoModal').classList.remove('open');
    document.body.style.overflow = '';
  }

  document.getElementById('fundoModalClose').addEventListener('click', closeFundoModal);
  document.getElementById('fundoModalPrev').addEventListener('click', function() {
    var idx = fundoOrder.indexOf(_currentFundoId);
    openFundoModal(fundoOrder[(idx - 1 + fundoOrder.length) % fundoOrder.length]);
  });
  document.getElementById('fundoModalNext').addEventListener('click', function() {
    var idx = fundoOrder.indexOf(_currentFundoId);
    openFundoModal(fundoOrder[(idx + 1) % fundoOrder.length]);
  });
  document.getElementById('fundoModal').addEventListener('click', function(e) { if (e.target === this) closeFundoModal(); });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { closeFundoModal(); document.getElementById('regulatorioModal').classList.remove('open'); document.body.style.overflow = ''; }
  });

  // Formulário de contato (Web3Forms)
  (function() {
    var form = document.getElementById('contactForm');
    var status = document.getElementById('contactFormStatus');
    if (!form || !status) return;
    var submitBtn = form.querySelector('.form-submit');
    var submitLabel = submitBtn.textContent;

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';
      status.className = 'form-status';
      status.textContent = '';

      fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: new FormData(form)
      })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.success) {
            form.reset();
            status.textContent = 'Mensagem enviada com sucesso. Em breve entraremos em contato.';
            status.className = 'form-status show success';
          } else {
            status.textContent = 'Não foi possível enviar sua mensagem. Tente novamente ou fale pelo WhatsApp.';
            status.className = 'form-status show error';
          }
        })
        .catch(function() {
          status.textContent = 'Não foi possível enviar sua mensagem. Tente novamente ou fale pelo WhatsApp.';
          status.className = 'form-status show error';
        })
        .finally(function() {
          submitBtn.disabled = false;
          submitBtn.textContent = submitLabel;
        });
    });
  })();
</script>

</Base>
