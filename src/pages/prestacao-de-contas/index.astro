---
import Base from '../../layouts/Base.astro';
import { getPrestacaoContas } from '../../lib/sanity';
import { toHTML } from '@portabletext/to-html';

const doc = await getPrestacaoContas();
if (!doc) return Astro.redirect('/');

function slugify(text: string): string {
  return text.toLowerCase().normalize('NFD').replace(/[^a-z0-9\s]/g, '').trim().replace(/\s+/g, '-');
}

const corpoHTML = doc.corpo ? toHTML(doc.corpo, {
  components: {
    block: {
      h2: (props: any) => {
        const text = (props.value.children || []).map((c: any) => c.text || '').join('');
        return '<h2 id="' + slugify(text) + '">' + props.children + '</h2>';
      },
      legenda: (props: any) => '<p class="pub-legenda">' + props.children + '</p>',
      regulatorio: (props: any) => '<p class="pub-regulatorio">' + props.children + '</p>',
    },
    types: {
      codigoEmbutido: (props: any) => '<div class="pub-codigo-embutido">' + (props.value.codigo || '') + '</div>',
      image: (props: any) => {
        const src = props.value && props.value.assetUrl ? props.value.assetUrl : '';
        const legenda = props.value && props.value.legenda ? props.value.legenda : '';
        if (!src) return '';
        let fig = '<figure class="pub-figura"><img src="' + src + '" alt="' + legenda + '" />';
        if (legenda) fig += '<figcaption class="pub-legenda">' + legenda + '</figcaption>';
        return fig + '</figure>';
      },
    },
  },
}) : '';

const colunas = [
  { key: 'faturamentoTotal', label: 'Faturamento Total' },
  { key: 'despesasOperacionais', label: 'Despesas Operacionais*' },
  { key: 'faturamentoAntesIR', label: 'Faturamento antes do IR' },
  { key: 'valorInvestimentoEsporte', label: 'Valor de Investimento no Esporte' },
];

const tabela = doc.tabela || [];
const temTabela = tabela.length > 0;
const pageTitle = doc.titulo + ' — MZR Family Office';
---

<Base title={pageTitle} ogImage={doc.ogImagemUrl || undefined} ogType="article">

  <style>
    .pub-interna-header { background: var(--navy-700); padding: 72px 0 64px; }
    .pub-interna-back {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 12px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
      color: rgba(255,255,255,0.45); text-decoration: none; margin-bottom: 32px; transition: color 0.2s;
    }
    .pub-interna-back:hover { color: var(--gold-400); }
    .pub-interna-tag {
      font-size: 10px; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--gold-400); margin-bottom: 16px;
    }
    .pub-interna-title {
      font-family: 'Spectral', serif; font-weight: 400; font-size: clamp(28px, 3vw, 44px);
      color: #fff; line-height: 1.15; letter-spacing: -0.02em; margin: 0;
    }

    .pub-interna-corpo { background: var(--neutral-100); padding: 48px 0 96px; }
    .pub-interna-corpo .section-inner { max-width: 1080px; }
    .pub-corpo-box {
      background: #fff; border-radius: 16px; padding: 56px 64px;
      box-shadow: 0 2px 24px rgba(29,53,87,0.06); min-width: 0; overflow: hidden;
    }
    .pub-corpo-box + .pub-corpo-box { margin-top: 32px; }

    .pub-corpo-content { line-height: 1.80; color: var(--neutral-700); overflow-wrap: break-word; word-break: break-word; }
    .pub-corpo-content :global(p) { font-size: 17px; margin-bottom: 24px; }
    .pub-corpo-content :global(p:last-child) { margin-bottom: 0; }
    .pub-corpo-content :global(h2) { font-family: 'Spectral', serif; font-weight: 400; font-size: 28px; color: var(--navy-700); margin: 48px 0 20px; line-height: 1.2; }
    .pub-corpo-content :global(h2:first-child) { margin-top: 0; }
    .pub-corpo-content :global(h3) { font-family: 'Spectral', serif; font-weight: 400; font-size: 22px; color: var(--navy-700); margin: 36px 0 16px; line-height: 1.25; }
    .pub-corpo-content :global(strong) { color: var(--navy-800); font-weight: 600; }
    .pub-corpo-content :global(em) { font-style: italic; }
    .pub-corpo-content :global(a) { color: var(--gold-500); text-decoration: underline; }
    .pub-corpo-content :global(a:hover) { color: var(--gold-400); }
    .pub-corpo-content :global(ul), .pub-corpo-content :global(ol) { margin: 0 0 24px 24px; }
    .pub-corpo-content :global(li) { font-size: 17px; margin-bottom: 8px; }
    .pub-corpo-content :global(blockquote) { border-left: 3px solid var(--gold-400); padding: 4px 0 4px 24px; margin: 32px 0; color: var(--neutral-500); font-style: italic; font-size: 18px; }
    .pub-corpo-content :global(img) { display: block; width: 100%; max-width: 100%; height: auto; margin: 32px 0; }
    .pub-corpo-content :global(.pub-figura) { margin: 32px 0; }
    .pub-corpo-content :global(.pub-figura img) { margin: 0; }
    .pub-corpo-content :global(.pub-legenda) { font-size: 13px !important; color: var(--neutral-400) !important; text-align: center; margin-top: 10px !important; margin-bottom: 0 !important; font-style: italic; line-height: 1.5; }
    .pub-corpo-content :global(.pub-codigo-embutido) { margin: 32px 0; max-width: 100%; overflow-x: auto; }
    .pub-corpo-content :global(iframe) { display: block; width: 100%; max-width: 100%; border: 0; margin: 32px 0; }
    .pub-corpo-content :global(.pub-regulatorio) { font-size: 8px !important; color: var(--neutral-400); line-height: 1.4; text-align: justify; text-align-last: center; margin: 24px 0; }

    .pc-tabela-titulo { font-family: 'Spectral', serif; font-weight: 400; font-size: 24px; color: var(--navy-700); margin: 0 0 24px; }

    .pc-table-wrap { width: 100%; }
    .pc-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .pc-table thead th {
      font-size: 11px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
      color: var(--navy-700); text-align: center; padding: 0 14px 14px; vertical-align: bottom;
      border-bottom: 2px solid var(--gold-400);
    }
    .pc-table thead th:first-child { text-align: left; }
    .pc-table tbody td { padding: 18px 14px; text-align: center; color: var(--neutral-700); border-bottom: 1px solid rgba(29,53,87,0.08); }
    .pc-table tbody td:first-child { text-align: left; font-weight: 600; color: var(--navy-700); white-space: nowrap; }
    .pc-table tbody tr:last-child td { border-bottom: none; }
    .pc-download {
      display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600;
      color: var(--gold-500); text-decoration: none; transition: color 0.2s;
    }
    .pc-download:hover { color: var(--gold-400); }
    .pc-download svg { width: 14px; height: 14px; }
    .pc-vazio { color: var(--neutral-400); }

    .pc-rodape { margin-top: 20px; font-size: 12px; color: var(--neutral-400); line-height: 1.6; white-space: pre-line; }

    .pc-accordion { display: none; }
    .pc-acc-item { border-bottom: 1px solid rgba(29,53,87,0.10); }
    .pc-acc-item summary {
      list-style: none; cursor: pointer; padding: 18px 4px;
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
      font-weight: 600; color: var(--navy-700); font-size: 16px;
    }
    .pc-acc-item summary::-webkit-details-marker { display: none; }
    .pc-acc-chevron { flex-shrink: 0; transition: transform 0.25s ease; color: var(--gold-500); }
    .pc-acc-item[open] .pc-acc-chevron { transform: rotate(180deg); }
    .pc-acc-body { padding: 4px 4px 20px; }
    .pc-acc-row { display: flex; justify-content: space-between; gap: 16px; padding: 9px 0; border-top: 1px dashed rgba(29,53,87,0.10); }
    .pc-acc-row:first-child { border-top: none; }
    .pc-acc-label { font-size: 13px; color: var(--neutral-400); }
    .pc-acc-value { font-size: 14px; color: var(--neutral-700); font-weight: 500; text-align: right; white-space: nowrap; flex-shrink: 0; }
    .pc-acc-nf { margin-top: 14px; }

    @media (max-width: 768px) {
      .pub-interna-header { padding: 56px 0 48px; }
      .pub-corpo-box { padding: 32px 24px; border-radius: 12px; }
      .pub-corpo-content :global(p), .pub-corpo-content :global(li) { font-size: 16px; }
      .pub-corpo-content :global(h2) { font-size: 23px; }
      .pub-corpo-content :global(h3) { font-size: 19px; }
      .pc-table-wrap { display: none; }
      .pc-accordion { display: block; }
    }
  </style>

  <div class="pub-interna-header">
    <div class="section-inner">
      <a href="/#fundos" class="pub-interna-back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Fundos
      </a>
      <h1 class="pub-interna-title">{doc.titulo}</h1>
    </div>
  </div>

  <section class="pub-interna-corpo">
    <div class="section-inner">
      {corpoHTML && (
        <div class="pub-corpo-box">
          <div class="pub-corpo-content" set:html={corpoHTML} />
        </div>
      )}

      {temTabela && (
        <div class="pub-corpo-box">
          <h2 class="pc-tabela-titulo">Prestação de Contas</h2>

          <div class="pc-table-wrap">
            <table class="pc-table">
              <thead>
                <tr>
                  <th>Período</th>
                  {colunas.map((c) => <th>{c.label}</th>)}
                  <th>Comprovante (Nota Fiscal)</th>
                </tr>
              </thead>
              <tbody>
                {tabela.map((row: any) => (
                  <tr>
                    <td>{row.periodo}</td>
                    {colunas.map((c) => <td>{row[c.key] || '—'}</td>)}
                    <td>
                      {row.notaFiscalUrl ? (
                        <a class="pc-download" href={row.notaFiscalUrl} target="_blank" rel="noopener" download>
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                          Download
                        </a>
                      ) : (
                        <span class="pc-vazio">—</span>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="pc-accordion">
            {tabela.map((row: any) => (
              <details class="pc-acc-item">
                <summary>
                  <span>{row.periodo}</span>
                  <svg class="pc-acc-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </summary>
                <div class="pc-acc-body">
                  {colunas.map((c) => (
                    <div class="pc-acc-row">
                      <span class="pc-acc-label">{c.label}</span>
                      <span class="pc-acc-value">{row[c.key] || '—'}</span>
                    </div>
                  ))}
                  <div class="pc-acc-nf">
                    {row.notaFiscalUrl ? (
                      <a class="pc-download" href={row.notaFiscalUrl} target="_blank" rel="noopener" download>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        Baixar Nota Fiscal
                      </a>
                    ) : (
                      <span class="pc-vazio">Nota fiscal indisponível</span>
                    )}
                  </div>
                </div>
              </details>
            ))}
          </div>

          {doc.notaRodape && <p class="pc-rodape">{doc.notaRodape}</p>}
        </div>
      )}
    </div>
  </section>

</Base>
